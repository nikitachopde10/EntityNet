# EntityNet runs entirely offline by default. All keys below are OPTIONAL.

# --- Optional: free LLM via Groq (https://console.groq.com/) ---
# Enables richer entity extraction from news. Project works without it.
GROQ_API_KEY=

# --- Optional: free LLM via Google Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Optional: HuggingFace token for benchmark dataset upload ---
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Storage paths (defaults shown) ---
KUZU_PATH=data/graph.kuzu
CHROMA_PATH=data/chroma
